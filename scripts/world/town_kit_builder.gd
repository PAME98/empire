var _packed_cache := {}

func _ready() -> void:
	get_tree().node_added.connect(_on_node_added)

func _on_node_added(node: Node) -> void:
	var sp := node.scene_file_path
	if sp == "":
		return
	var key := sp.get_file()
	if not BUILDINGS.has(key):
		return
	if node.is_node_ready():
		_populate(node, key)
	else:
		node.ready.connect(_populate.bind(node, key), CONNECT_ONE_SHOT)

func _populate(node: Node, key: String) -> void:
	if not is_instance_valid(node):
		return
	var fm := node.get_node_or_null("FinishedMesh")
	if fm == null:
		push_warning("TownKitBuilder: no FinishedMesh on " + node.name)
		return
	for c in fm.get_children():
		c.queue_free()
	for pc in BUILDINGS[key]:
		var packed := _load_packed(pc["m"])
		if packed == null:
			continue
		var inst := packed.instantiate()
		inst.scale = (pc["s"] as Vector3) * UNIT
		inst.rotation = Vector3(0.0, deg_to_rad(pc["r"]), 0.0)
		inst.position = (pc["p"] as Vector3) * UNIT
		fm.add_child(inst)

func _load_packed(mesh_name: String) -> PackedScene:
	if _packed_cache.has(mesh_name):
		return _packed_cache[mesh_name]
	var packed := load(ASSET_DIR + mesh_name) as PackedScene
	if packed == null:
		push_warning("TownKitBuilder: could not load " + ASSET_DIR + mesh_name)
	_packed_cache[mesh_name] = packed
	return packed
